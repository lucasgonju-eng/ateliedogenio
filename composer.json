{
    "name": "atelie/estoque-fluxo",
    "description": "Ateli\u00ea do G\u00eanio - Sistema de controle de estoque, PDV e fluxo de caixa integrado ao Supabase.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "vlucas/phpdotenv": "^5.5",
        "nikic/fast-route": "^1.3",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.0",
        "http-interop/http-factory-guzzle": "^1.2",
        "monolog/monolog": "^3.5",
        "firebase/php-jwt": "^6.10",
        "symfony/mailer": "^7.0",
        "symfony/mime": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "symfony/var-dumper": "^7.0",
        "friendsofphp/php-cs-fixer": "^3.49"
    },
    "autoload": {
        "psr-4": {
            "AtelieDoGenio\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AtelieDoGenio\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "serve": "php -S localhost:8080 -t public",
        "test": "phpunit",
        "docs:endpoints": "php scripts/export-routes.php"
    }
}
