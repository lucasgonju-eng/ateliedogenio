RewriteEngine On

# Assets via /vendas/imagens/* usam os mesmos arquivos de /imagens/*
RewriteRule ^imagens/(.*)$ /imagens/$1 [L]

# Front controller da app para /vendas e subrotas
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index.php [L,QSA]
