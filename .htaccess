RewriteEngine On

# Em produção o app deve responder em /vendas

# Permite acesso direto a arquivos em /public (sem loop)
RewriteRule ^public/ - [L]

# Assets da aplicação quando chamados com prefixo /vendas
RewriteRule ^vendas/imagens/(.*)$ public/imagens/$1 [L]

# /vendas e /vendas/
RewriteRule ^vendas/?$ public/index.php [L,QSA]

# Qualquer rota da aplicação sob /vendas/*
RewriteRule ^vendas/.*$ public/index.php [L,QSA]
